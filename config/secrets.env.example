# Enchantify — secrets.env
# Copy this file to config/secrets.env and fill in your values.
# secrets.env is gitignored and never leaves your machine.
#
# The installer creates this file for you. Edit it any time.

# ─── Health Data ──────────────────────────────────────────────────────────────
# HEALTH_BACKEND options: health_auto_export (iPhone app), garmin, fitbit, manual, none
HEALTH_BACKEND=health_auto_export
# HEALTH_DIR: override the auto-detected iCloud path (usually leave blank)
# Only set this if your iCloud path is non-standard or you're using a custom export folder.
HEALTH_DIR=

# ─── Location ─────────────────────────────────────────────────────────────────
# Used for weather, tides, sunrise/sunset
LOCATION=Your+City+State
LAT=0.0000
LON=0.0000
NOAA_STATION=         # US coastal tides — find yours at tidesandcurrents.noaa.gov
HOME_WIFI=            # Your home WiFi SSID — used for presence detection

# ─── Email ────────────────────────────────────────────────────────────────────
GMAIL_USER=           # yourname@gmail.com
GMAIL_APP_PASS=       # App password from myaccount.google.com/apppasswords

# ─── Patreon ──────────────────────────────────────────────────────────────────
PATREON_TOKEN=        # Creator access token from patreon.com/portal/registration/register-clients
PATREON_ID=           # Your campaign ID

# ─── YouTube ──────────────────────────────────────────────────────────────────
YT_KEY=               # Google Cloud API key with YouTube Data API v3 enabled
YT_CH_ID=             # Your channel ID (starts with UC...)

# ─── Teller (financials) ──────────────────────────────────────────────────────
TELLER_TOKEN=         # From teller.io
TELLER_ACCOUNT_ID=    # Your account ID

# ─── Image generation ─────────────────────────────────────────────────────────
OPENAI_API_KEY=       # From platform.openai.com — for DALL-E 3
IMAGE_BACKEND=dalle3  # Options: dalle3, stable-diffusion, none

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=   # From @BotFather
TELEGRAM_CHAT_ID=     # Your chat ID with the bot

# ─── The Bleed (daily newspaper) ──────────────────────────────────────────────
# BLEED_PRINTER: CUPS printer name for physical print at 6pm. Leave blank to skip.
# Find printer names with: lpstat -p -d
# Requires wkhtmltopdf for PDF conversion (brew install wkhtmltopdf), otherwise prints HTML directly.
BLEED_PRINTER=        # e.g. HP_LaserJet_Pro
